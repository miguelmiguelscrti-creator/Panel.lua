-- Verifica se é jogo de FPS
local function IsFPS()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") and (obj.Name:lower():find("gun") or obj.Name:lower():find("arma") or obj.Name:lower():find("rifle")) then
            return true
        end
    end
    return false
end

